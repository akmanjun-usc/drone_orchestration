# Copy this to .env and fill in your keys
# The orchestrator loads this automatically (Phase 4)

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (optional — only needed if using GPT-4o provider)
OPENAI_API_KEY=sk-...

# Which provider to use: "anthropic" | "openai"
LLM_PROVIDER=anthropic

# Which model to use within the provider
# Anthropic examples: claude-opus-4-6  claude-sonnet-4-6  claude-haiku-4-5-20251001
# OpenAI examples:    gpt-4o  gpt-4o-mini
LLM_MODEL=claude-sonnet-4-6
