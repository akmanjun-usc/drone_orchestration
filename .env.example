# Copy this to .env and fill in your keys
# The orchestrator loads this automatically (Phase 4)

# ---------------------------------------------------------------
# API keys — fill in the ones you need, leave the rest blank
# ---------------------------------------------------------------

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (optional — only needed if using the openai provider)
OPENAI_API_KEY=sk-...

# Groq (optional — only needed if using the groq provider)
GROQ_API_KEY=gsk_...

# ---------------------------------------------------------------
# Provider selection
# Supported values: anthropic | openai | groq
# ---------------------------------------------------------------
LLM_PROVIDER=anthropic

# ---------------------------------------------------------------
# Model selection
# Pick a model that belongs to the provider you chose above
#
# Anthropic:   claude-opus-4-6
#              claude-sonnet-4-6
#              claude-haiku-4-5-20251001
#
# OpenAI:      gpt-4o
#              gpt-4o-mini
#
# Groq:        llama-3.3-70b-versatile   (best quality)
#              llama-3.1-8b-instant      (higher rate limit)
#              mixtral-8x7b-32768
#              gemma2-9b-it
# ---------------------------------------------------------------
LLM_MODEL=claude-sonnet-4-6

# ---------------------------------------------------------------
# AirSim connection (original AirSim)
# Only change these if AirSim is running on a different machine
# ---------------------------------------------------------------
AIRSIM_HOST=127.0.0.1
AIRSIM_PORT=41451

# ---------------------------------------------------------------
# Project AirSim connection
# Only change these if Project AirSim is on a different machine
# ---------------------------------------------------------------
PROJECT_AIRSIM_HOST=127.0.0.1
PROJECT_AIRSIM_PORT_TOPICS=4760
PROJECT_AIRSIM_PORT_SERVICES=4761
